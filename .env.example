# Application Configuration
APP_NAME=Image Generation & Printing API
APP_VERSION=1.0.0
DEBUG=False

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Google AI/Gemini API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Model Configuration
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_IMAGE=gemini-2.5-flash-image-preview
IMAGEN_MODEL=imagen-3.0-capability-001

# File Storage Configuration
UPLOAD_DIR=static/uploads
GENERATED_IMAGES_DIR=static/generated_images
OUTPUT_IMAGES_DIR=static/output_images
MAX_FILE_SIZE=10485760

# Logging Configuration
LOG_LEVEL=INFO

# CORS Configuration (adjust for production)
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
